{
  "name": "@starroy/ai-ping-web",
  "version": "1.3.0",
  "private": true,
  "description": "Browser-based AI Ping Web Playground Preview.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 11874",
    "build": "tsc -p tsconfig.json && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 11875",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@starroy/ai-ping-core": "workspace:*",
    "@starroy/ai-ping-report": "workspace:*",
    "@vitejs/plugin-react": "^5.0.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "vite": "^7.1.5"
  },
  "devDependencies": {
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
