{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Ping Desktop Preview",
  "version": "1.4.0",
  "identifier": "dev.howardxie.ai-ping.preview",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:11873",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Ping Desktop Preview",
        "width": 1180,
        "height": 820,
        "minWidth": 760,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "background": "assets/dmg-background.png",
        "windowSize": {
          "width": 660,
          "height": 413
        },
        "appPosition": {
          "x": 180,
          "y": 210
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 210
        }
      }
    }
  }
}
