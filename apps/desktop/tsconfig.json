{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDir": "../..",
    "baseUrl": ".",
    "paths": {
      "@starroy/ai-ping-core": ["../../packages/core/src/index.ts"],
      "@starroy/ai-ping-report": ["../../packages/report/src/index.ts"]
    },
    "resolveJsonModule": true,
    "types": ["vite/client"]
  },
  "include": ["src", "tests", "vite.config.ts"]
}
