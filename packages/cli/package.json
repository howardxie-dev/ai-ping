{
  "name": "@starroy/ai-ping",
  "version": "0.10.0",
  "description": "Quick protocol checks for AI and LLM API endpoints.",
  "license": "MIT",
  "type": "module",
  "author": "Howard Xie",
  "main": "./dist/index.js",
  "bin": {
    "aiping": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "llm",
    "api",
    "cli",
    "openai",
    "protocol",
    "smoke-test",
    "endpoint"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/howardxie-dev/ai-ping.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/howardxie-dev/ai-ping/issues"
  },
  "homepage": "https://github.com/howardxie-dev/ai-ping#readme",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "cli": "node dist/index.js",
    "pack:check": "pnpm build && npm_config_cache=../../.npm-pack-cache npm pack --dry-run",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@starroy/ai-ping-core": "0.10.0",
    "cac": "^6.7.14",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "vitest": "^4.0.15"
  }
}
