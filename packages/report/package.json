{
  "name": "@starroy/ai-ping-report",
  "version": "1.3.0",
  "private": true,
  "description": "Shared report renderers for AI Ping.",
  "license": "MIT",
  "type": "module",
  "author": "Howard Xie",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@starroy/ai-ping-core": "workspace:*",
    "tsup": "^8.5.0",
    "vitest": "^4.0.15"
  }
}
