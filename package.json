{
  "name": "ai-ping-workspace",
  "version": "1.4.0",
  "private": true,
  "description": "Quick protocol checks for AI and LLM API endpoints.",
  "license": "MIT",
  "type": "module",
  "author": "Howard Xie",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/howardxie-dev/ai-ping.git"
  },
  "bugs": {
    "url": "https://github.com/howardxie-dev/ai-ping/issues"
  },
  "homepage": "https://github.com/howardxie-dev/ai-ping#readme",
  "scripts": {
    "build": "pnpm -r build",
    "desktop:build:app": "pnpm --filter @starroy/ai-ping-desktop build:app",
    "desktop:build:dmg": "pnpm --filter @starroy/ai-ping-desktop build:dmg",
    "desktop:build:macos": "pnpm --filter @starroy/ai-ping-desktop build:macos",
    "desktop:build:windows": "pnpm --filter @starroy/ai-ping-desktop build:windows",
    "desktop:build:linux": "pnpm --filter @starroy/ai-ping-desktop build:linux",
    "desktop:dev": "pnpm --filter @starroy/ai-ping-desktop tauri:dev",
    "desktop:preview": "pnpm --filter @starroy/ai-ping-desktop dev",
    "web:build": "pnpm --filter @starroy/ai-ping-web build",
    "web:dev": "pnpm --filter @starroy/ai-ping-web dev",
    "web:preview": "pnpm --filter @starroy/ai-ping-web preview",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "pack:check": "pnpm -r --if-present pack:check"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.8.1"
}
